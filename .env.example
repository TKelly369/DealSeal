# DealSeal monorepo env reference.
# Copy app-specific examples instead:
# - apps/api/.env.example -> apps/api/.env
# - apps/web/.env.example -> apps/web/.env.local

# --- API (apps/api/.env)
DATABASE_URL=postgresql://user:pass@localhost:5432/dealseal
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-min-16-chars-for-production
PORT=4000
LOG_LEVEL=info

# CORS: comma-separated exact origins; leave empty to allow any origin (dev)
# CORS_ORIGIN=https://app.dealseal1.com,https://dealseal1.com

# S3-compatible storage (MinIO or AWS; API uses S3_* variable names)
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Optional custom endpoint (e.g. MinIO)
# S3_ENDPOINT=http://127.0.0.1:9000

# Same values as above, if you prefer standard AWS names in a single .env (map to S3_* in hosting):
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_PRICE_ID=
APP_PUBLIC_URL=https://app.dealseal1.com

# --- Web (apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public site URL (links, CORS in browser; no hardcoded domain in app code)
NEXT_PUBLIC_APP_URL=http://localhost:3000

