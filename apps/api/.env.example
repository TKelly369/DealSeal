# Core runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Required
DATABASE_URL=postgresql://user:pass@localhost:5432/dealseal
JWT_SECRET=change-me-min-16-chars-for-production

# Optional in local dev; recommended in production for workers/queues
REDIS_URL=redis://127.0.0.1:6379

# Comma-separated allowed web origins.
# Required in production (e.g. https://app.dealseal1.com,https://dealseal1.com)
CORS_ORIGIN=

# Object storage
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# S3_ENDPOINT=

# Billing / checkout (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_PRICE_ID=
APP_PUBLIC_URL=http://localhost:3000
# Public web origin for QR and links. Must be a full public origin; QR = `${VERIFICATION_PUBLIC_BASE_URL}/verify/${recordId}`.
# If unset, falls back to APP_PUBLIC_URL.
VERIFICATION_PUBLIC_BASE_URL=http://localhost:3000
# Optional. Documented for workers / server-side callers; main API does not require it. Next.js can use this to call the API on a private URL.
API_INTERNAL_URL=

# Basic request limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
API_RATE_LIMIT_MAX=120
