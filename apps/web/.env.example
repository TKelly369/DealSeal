# --- AI (server-side; required for onboarding extraction & compliance LLM calls)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides (defaults: claude-3-5-sonnet-20240620, gpt-4o)
# ANTHROPIC_PRIMARY_MODEL=
# OPENAI_FAST_MODEL=

# NextAuth / Auth.js — set AUTH_SECRET (or NEXTAUTH_SECRET) for any public deployment.
# If unset, the app uses a built-in demo secret so local login still works (not for real prod).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Demo only: allow scaffolded MOCK_USERS (user@dealseal1.com / dealseal123, etc.) in production.
# Omit or set false when using real DB-backed users.
# DEALSEAL_ALLOW_SCAFFOLD_LOGIN=true
# Legacy alias; some next-auth/react paths still read this.
NEXTAUTH_SECRET=
# Match the origin you use in the browser (http + port) so session cookies work on plain HTTP.
# Production: https://your-domain.com
AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# AES-256-GCM field encryption for regulated PII at rest (buyer tax ID, bank, gov ID vault on DealParty).
# Production: required (base64-encoded 32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

# Custodial object storage: `local` (filesystem under LOCAL_STORAGE_ROOT) or `s3` when S3_* are set.
# STORAGE_DRIVER=
# STORAGE_ENVIRONMENT=development
# LOCAL_STORAGE_ROOT=.data/dealseal-storage

# Public URL for backend API consumed by browser code
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side: call API on a private base URL (Docker / internal). If unset, uses NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=

# Optional public app URL used for metadata/canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000
