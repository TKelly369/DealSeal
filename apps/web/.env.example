# --- AI (server-side; required for onboarding extraction & compliance LLM calls)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides (defaults: claude-3-5-sonnet-20240620, gpt-4o)
# ANTHROPIC_PRIMARY_MODEL=
# OPENAI_FAST_MODEL=

# NextAuth / Auth.js — set AUTH_SECRET (or NEXTAUTH_SECRET) for any public deployment.
# If unset, the app uses a built-in demo secret so local login still works (not for real prod).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Legacy alias; some next-auth/react paths still read this.
NEXTAUTH_SECRET=
# Match the origin you use in the browser (http + port) so session cookies work on plain HTTP.
# Production: https://your-domain.com
AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# Public URL for backend API consumed by browser code
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side: call API on a private base URL (Docker / internal). If unset, uses NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=

# Optional public app URL used for metadata/canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000
