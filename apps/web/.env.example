# --- AI (server-side; required for onboarding extraction & compliance LLM calls)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides (defaults: claude-3-5-sonnet-20240620, gpt-4o)
# ANTHROPIC_PRIMARY_MODEL=
# OPENAI_FAST_MODEL=

# Public URL for backend API consumed by browser code
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side: call API on a private base URL (Docker / internal). If unset, uses NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=

# Optional public app URL used for metadata/canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000
