# NextAuth — use a strong random secret; never commit the real value.
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=https://app.dealseal1.com
NEXTAUTH_URL=https://app.dealseal1.com

# Public API URL used by browser requests
NEXT_PUBLIC_API_URL=https://api.dealseal1.com

# Server-only: internal API base for Next.js route handlers (e.g. /api/verify proxy). If unset, NEXT_PUBLIC_API_URL is used.
API_INTERNAL_URL=http://api:4000

# Public app URL used for metadata/canonical references
NEXT_PUBLIC_APP_URL=https://app.dealseal1.com
