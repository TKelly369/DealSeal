// Prisma client for `apps/web` (Next.js). Path must match `db:generate` in root package.json (rimraf target).
generator client {
  provider      = "prisma-client-js"
  output        = "../apps/web/src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEALER_USER
  DEALER_MANAGER
  LENDER_USER
  LENDER_MANAGER
  ADMIN_USER
  CUSTODIAN_ADMIN
  SUPER_ADMIN
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentStatus {
  PENDING
  CERTIFIED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceType {
  DEALERSHIP
  LENDER
  /// DealSeal platform staff (admin console); not a dealer or lender org.
  INTERNAL
}

enum VehicleTypeSelection {
  NEW
  USED
  BOTH
}

enum SigningMethod {
  WET
  E_SIGN
  HYBRID
}

enum LenderEntityType {
  BANK
  CU
  CAPTIVE
  FINANCE
}

enum AssignmentType {
  IMMEDIATE
  CONDITIONAL
  POST_FUNDING
}

enum DealerLenderLinkStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum DealStatus {
  DISCLOSURE_REQUIRED
  DISCLOSURE_PENDING
  DISCLOSURE_SIGNED
  MOCKUP_SUBMITTED
  LENDER_REVIEW
  LENDER_COUNTER
  BUYER_REAUTH_PENDING
  LENDER_FINAL_APPROVAL
  FINAL_PACKAGE_GENERATED
  AWAITING_LIVE_SIGNATURES
  AWAITING_FUNDING_UPLOAD
  FUNDED
  AUTHORIZED_FOR_STRUCTURING
  GREEN_STAGE
  RISC_UNSIGNED_REVIEW
  RISC_LENDER_FINAL
  FIRST_GREEN_PASSED
  AUTHORITATIVE_LOCK
  GENERATING_CLOSING_PACKAGE
  CLOSING_PACKAGE_READY
  CONSUMMATED
}

enum MockupLenderStatus {
  PENDING
  APPROVED_NO_CHANGES
  COUNTER_OFFERED
  REJECTED
}

enum CustodyEventType {
  UPLOADED
  GENERATED
  VIEWED
  MODIFIED
  SIGNED
  LOCKED
  CERTIFIED
  INITIAL_DISCLOSURE_ACCEPTED
  CHANGE_SUMMARY_GENERATED
  DOWNLOADED
  PACKAGE_EXPORTED
}

enum DocumentLifecycleStage {
  UPLOADED_OR_GENERATED
  VALIDATED
  LINKED_AUTHORITATIVE
  IN_SUBMISSION
  LOCKED
  ARCHIVED
}

enum DocumentProvenance {
  DEALER
  LENDER
  SYSTEM
}

enum DocumentType {
  INITIAL_DISCLOSURE_SIGNED
  CHANGE_SUMMARY_DISCLOSURE
  PROCESS_DISCLOSURE
  DEALER_UPLOAD
  /// Bureau or dealer-sourced credit file uploaded by dealer; DealSeal does not pull credit.
  CREDIT_REPORT_UPLOAD
  INSURANCE
  RISC_UNSIGNED
  RISC_LENDER_FINAL
  RISC_SIGNED
  BMV_LIEN_CERT
  BUYER_PACKAGE
  UCSP_BUYERS_ORDER
  UCSP_STATE_DISCLOSURE
  UCSP_ASSIGNMENT
  UCSP_TITLE_APPLICATION
  UCSP_CLOSING_MANIFEST
}

enum DealComplianceStatus {
  COMPLIANT
  WARNING
  BLOCKED
}

enum ContractTransactionEventType {
  DEALER_ASSIGNMENT_TO_LENDER
  LENDER_SALE_TO_TRUST
  POOL_TRANSFER
  AMENDMENT_APPROVED
}

enum LoanPoolType {
  WHOLE_LOAN
  SECURITIZATION
  PRIME
  NEAR_PRIME
  SUBPRIME
  MIXED
  CUSTOM
}

enum LoanPoolStatus {
  DRAFT
  FORMING
  ACTIVE
  LOCKED
  CLOSED
  SOLD
  ARCHIVED
  IN_REVIEW
  READY_FOR_SALE
  TRANSFERRED
}

/// High-level sale / transfer workflow for secondary readiness (lender-defined stages).
enum LoanPoolSaleStage {
  NONE
  IN_REVIEW
  READY_FOR_SALE
  SOLD
  TRANSFERRED
}

enum RecourseStatus {
  WITH_RECOURSE
  WITHOUT_RECOURSE
}

enum SecondaryMarketStatus {
  HELD_FOR_INVESTMENT
  AVAILABLE_FOR_SALE
  SOLD
}

enum AmendmentReason {
  BMV_REJECTION
  VIN_CORRECTION
  FINANCIAL_ADJUSTMENT
}

enum AmendmentStatus {
  PENDING_LENDER_APPROVAL
  APPROVED
  REJECTED
}

enum NegotiableInstrumentType {
  PROMISSORY_NOTE
  RISC_AS_NOTE
}

enum InstrumentTransferType {
  ENDORSEMENT
  NEGOTIATION
  SALE_WITHOUT_RECOURSE
}

enum HdcStatus {
  UNEVALUATED
  QUALIFIED
  REVIEW_REQUIRED
  DEFECTIVE
}

enum DealPartyRole {
  BUYER
  CO_BUYER
}

enum VehicleCondition {
  NEW
  USED
}

enum GeneratedDocumentType {
  CONTRACT
  DISCLOSURE
  BUYERS_ORDER
  FUNDING_PACKET
  INITIAL_DISCLOSURE
  MOCKUP_CONTRACT
  MOCKUP_PACKET
  FINAL_RISC
  FINAL_COORDINATED_PACKAGE
}

enum ComplianceRuleSet {
  STATE
  LENDER
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DealAlertStatus {
  OPEN
  CLEARED
  OVERRIDDEN
}

enum DealAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum LenderTaskCategory {
  dealer_relationship
  deal_intake
  contract_integrity
  funding
  post_funding
  enforcement_readiness
  pooling
  secondary_market
  document_custody
}

enum LenderTaskPriority {
  low
  medium
  high
  critical
}

enum LenderTaskStatus {
  open
  in_progress
  blocked
  completed
  cancelled
  overdue
}

enum MissingItemRequestStatus {
  requested
  uploaded
  accepted
  rejected
  overdue
}

enum MissingItemReviewStatus {
  pending
  accepted
  rejected
}

enum VaultRecordClass {
  GOVERNING_CONTRACT
  DEAL_JACKET
  AUDIT_LOG
  CUSTODY_EVENT
  PACKAGE_MANIFEST
}

enum PurgeJobStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum DealAlertAuditAction {
  ALERT_ISSUED
  ALERT_SENT
  CLEARED
  OVERRIDDEN
}

/// Dealer workspace calendar (follow-ups, funding, signing, conditions, title).
enum CalendarEventKind {
  FOLLOW_UP
  DOCUMENT_REMINDER
  FUNDING_TASK
  CUSTOMER_SIGNING
  LENDER_CONDITION
  TITLE_REGISTRATION
  REPO_REPLEVIN_REVIEW
  INTERNAL_NOTE
  ALERT_REMINDER
}

model User {
  id                      String            @id @default(cuid())
  email                   String            @unique
  name                    String?
  role                    UserRole          @default(DEALER_USER)
  /// Home organization (Workspace). Must match role: dealer → DEALERSHIP, lender → LENDER, admin → INTERNAL.
  organizationWorkspaceId String
  organizationWorkspace   Workspace         @relation("UserOrganization", fields: [organizationWorkspaceId], references: [id], onDelete: Restrict)
  image                   String?
  accounts                Account[]
  sessions                Session[]
  memberships             Membership[]
  requestedAmendments     Amendment[]       @relation("AmendmentRequester")
  approvedAmendments      Amendment[]       @relation("AmendmentApprover")
  notifications           Notification[]
  accessAudits            UserAccessAudit[]
  dealCommentsAuthored    DealComment[]     @relation("DealCommentAuthor")
  dealCommentsResolved    DealComment[]     @relation("DealCommentResolver")
  loanPoolsCreated        LoanPool[]        @relation("LoanPoolCreatedBy")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}

model Workspace {
  id                        String                   @id @default(cuid())
  name                      String
  slug                      String                   @unique
  type                      WorkspaceType            @default(DEALERSHIP)
  organizationUsers         User[]                   @relation("UserOrganization")
  memberships               Membership[]
  documents                 Document[]
  subscriptions             Subscription[]
  dealerProfile             DealerProfile?
  lenderProfile             LenderProfile?
  dealerLinks               DealerLenderLink[]       @relation("DealerWorkspaceLinks")
  lenderLinks               DealerLenderLink[]       @relation("LenderWorkspaceLinks")
  dealerOnboardingAnswers   DealerOnboardingAnswer[] @relation("DealerWorkspaceAnswers")
  lenderOnboardingAnswers   LenderOnboardingAnswer[] @relation("LenderWorkspaceAnswers")
  dealerDeals               Deal[]                   @relation("DealerDeals")
  lenderDeals               Deal[]                   @relation("LenderDeals")
  notifications             Notification[]
  dealAlerts                DealAlert[]
  loanPools                 LoanPool[]
  apiKeys                   ApiKey[]
  webhookEndpoints          WebhookEndpoint[]
  accessAudits              UserAccessAudit[]
  dealCountCurrentPeriod    Int                      @default(0)
  calendarEvents            CalendarEvent[]
  lenderTasks               LenderTask[]             @relation("LenderWorkspaceTasks")
  dealerTasks               LenderTask[]             @relation("DealerWorkspaceTasks")
  lenderMissingItemRequests MissingItemRequest[]     @relation("LenderWorkspaceMissingItems")
  dealerMissingItemRequests MissingItemRequest[]     @relation("DealerWorkspaceMissingItems")
  retentionPolicies         RetentionPolicy[]
  purgeJobs                 PurgeJob[]
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
}

model CalendarEvent {
  id          String            @id @default(cuid())
  workspaceId String
  kind        CalendarEventKind
  title       String
  notes       String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean           @default(false)
  dealId      String?
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([workspaceId, startsAt])
  @@index([dealId])
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(MEMBER)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Document {
  id          String         @id @default(cuid())
  workspaceId String
  title       String
  type        String
  status      DocumentStatus @default(PENDING)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([workspaceId, createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  workspaceId            String             @unique
  stripeCustomerId       String?
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  status                 SubscriptionStatus @default(CANCELED)
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model DealerProfile {
  id                            String               @id @default(cuid())
  workspaceId                   String               @unique
  legalName                     String
  dba                           String?
  stateOfFormation              String
  licenseNumber                 String?
  operatingStates               String[]
  dmsProvider                   String?
  vehicleTypes                  VehicleTypeSelection @default(BOTH)
  addOnsOffered                 String[]
  signingMethod                 SigningMethod        @default(HYBRID)
  /// Workspace-level opening disclosure on file — required before deal workflows unlock.
  openingDisclosureUploadedAt   DateTime?
  openingDisclosureStorageKey   String?
  openingDisclosureOriginalName String?
  openingDisclosureSha256       String?
  workspace                     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
}

model LenderProfile {
  id                  String           @id @default(cuid())
  workspaceId         String           @unique
  legalName           String
  entityType          LenderEntityType
  licensedStates      String[]
  acceptedDealerTypes String[]
  assignmentType      AssignmentType
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model DealerLenderLink {
  id                String                 @id @default(cuid())
  dealerId          String
  lenderId          String
  status            DealerLenderLinkStatus @default(PENDING)
  approvedStates    String[]
  allowedDealTypes  String[]
  lenderOverrides   Json                   @default("{}")
  /// JSON profile for lender-facing disclosure (e.g. `{ "showDealerFeeBreakdown": false }`).
  lenderRuleProfile Json                   @default("{}")
  effectiveDate     DateTime?
  expirationDate    DateTime?
  requestedBy       String?
  approvedBy        String?
  auditTrail        Json                   @default("[]")
  dealer            Workspace              @relation("DealerWorkspaceLinks", fields: [dealerId], references: [id], onDelete: Cascade)
  lender            Workspace              @relation("LenderWorkspaceLinks", fields: [lenderId], references: [id], onDelete: Cascade)
  deals             Deal[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([dealerId, lenderId])
}

model DealerOnboardingAnswer {
  id            String    @id @default(cuid())
  dealerId      String
  questionKey   String
  answerValue   Json
  ruleInference Json      @default("{}")
  dealer        Workspace @relation("DealerWorkspaceAnswers", fields: [dealerId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model LenderOnboardingAnswer {
  id            String    @id @default(cuid())
  lenderId      String
  questionKey   String
  answerValue   Json
  ruleInference Json      @default("{}")
  lender        Workspace @relation("LenderWorkspaceAnswers", fields: [lenderId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Deal {
  id                              String                           @id @default(cuid())
  dealerId                        String
  lenderId                        String
  dealerLenderLinkId              String
  status                          DealStatus                       @default(DISCLOSURE_REQUIRED)
  state                           String
  initialDisclosureAcceptedAt     DateTime?
  initialDisclosureHash           String?
  initialDisclosureSignerName     String?
  dealerRepresentativeName        String?
  governingStateProfile           Json?
  preliminarySubmittedTerms       Json?
  lenderApprovedTerms             Json?
  mockupLenderStatus              MockupLenderStatus               @default(PENDING)
  requiresBuyerReauth             Boolean                          @default(false)
  finalPackageHash                String?
  complianceStatus                DealComplianceStatus             @default(COMPLIANT)
  consummatedData                 Json?
  poolId                          String?
  secondaryMarketStatus           SecondaryMarketStatus            @default(HELD_FOR_INVESTMENT)
  secondaryMarketGrade            String?
  dealer                          Workspace                        @relation("DealerDeals", fields: [dealerId], references: [id], onDelete: Cascade)
  lender                          Workspace                        @relation("LenderDeals", fields: [lenderId], references: [id], onDelete: Cascade)
  dealerLenderLink                DealerLenderLink                 @relation(fields: [dealerLenderLinkId], references: [id], onDelete: Restrict)
  loanPool                        LoanPool?                        @relation(fields: [poolId], references: [id], onDelete: SetNull)
  parties                         DealParty[]
  vehicle                         Vehicle?
  financials                      DealFinancials?
  authoritativeContract           AuthoritativeContract?
  generatedDocuments              GeneratedDocument[]
  custodyEvents                   DocumentCustodyEvent[]
  complianceChecks                ComplianceCheck[]
  prefundingValidationCertificate PreFundingValidationCertificate?
  contractTransactionEvents       ContractTransactionEvent[]
  negotiableInstrument            NegotiableInstrument?
  instrumentTransferEvents        InstrumentTransferEvent[]
  amendments                      Amendment[]
  notifications                   Notification[]
  alerts                          DealAlert[]
  apiIngressKeyId                 String?
  comments                        DealComment[]
  auditEvents                     DealAuditEvent[]
  calendarEvents                  CalendarEvent[]
  lenderTasks                     LenderTask[]
  missingItemRequests             MissingItemRequest[]
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt

  @@index([lenderId, secondaryMarketStatus])
  @@index([poolId])
}

model LenderTask {
  id           String             @id @default(cuid())
  lenderId     String
  dealId       String?
  dealerId     String?
  poolId       String?
  title        String
  description  String?
  category     LenderTaskCategory
  priority     LenderTaskPriority @default(medium)
  status       LenderTaskStatus   @default(open)
  dueDate      DateTime?
  assignedTo   String?
  source       String?
  auditEventId String?
  completedAt  DateTime?
  lender       Workspace          @relation("LenderWorkspaceTasks", fields: [lenderId], references: [id], onDelete: Cascade)
  dealer       Workspace?         @relation("DealerWorkspaceTasks", fields: [dealerId], references: [id], onDelete: SetNull)
  deal         Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  pool         LoanPool?          @relation(fields: [poolId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([lenderId, status, dueDate])
  @@index([dealId, category])
  @@index([poolId])
}

model MissingItemRequest {
  id                 String                   @id @default(cuid())
  lenderId           String
  dealerId           String
  dealId             String
  requestedItemType  String
  description        String?
  required           Boolean                  @default(true)
  priority           LenderTaskPriority       @default(medium)
  dueDate            DateTime?
  status             MissingItemRequestStatus @default(requested)
  requestedBy        String
  uploadedDocumentId String?
  lenderReviewStatus MissingItemReviewStatus  @default(pending)
  lender             Workspace                @relation("LenderWorkspaceMissingItems", fields: [lenderId], references: [id], onDelete: Cascade)
  dealer             Workspace                @relation("DealerWorkspaceMissingItems", fields: [dealerId], references: [id], onDelete: Cascade)
  deal               Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt          DateTime                 @default(now())
  resolvedAt         DateTime?
  updatedAt          DateTime                 @updatedAt

  @@index([lenderId, status, dueDate])
  @@index([dealerId, status])
  @@index([dealId, status])
}

model RetentionPolicy {
  id              String           @id @default(cuid())
  workspaceId     String
  recordClass     VaultRecordClass
  jurisdiction    String           @default("US")
  retentionYears  Int
  purgeMode       String           @default("HASH_ONLY")
  legalHoldExempt Boolean          @default(false)
  enabled         Boolean          @default(true)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purgeJobs       PurgeJob[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([workspaceId, recordClass, jurisdiction])
  @@index([workspaceId, enabled])
}

model PurgeJob {
  id                String           @id @default(cuid())
  workspaceId       String
  policyId          String?
  status            PurgeJobStatus   @default(SCHEDULED)
  dryRun            Boolean          @default(false)
  scheduledAt       DateTime
  startedAt         DateTime?
  finishedAt        DateTime?
  initiatedByUserId String?
  summary           Json             @default("{}")
  errorMessage      String?
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policy            RetentionPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([workspaceId, status, scheduledAt])
}

model DealParty {
  id              String        @id @default(cuid())
  dealId          String
  role            DealPartyRole
  firstName       String
  lastName        String
  address         String
  creditTier      String?
  /// AES-256-GCM encrypted PII payload + IV references (see `field-encryption.ts`).
  encryptedPii    Json?
  /// Logical KMS / vault key identifier stored alongside ciphertext (e.g. ARN or `env:FIELD_ENCRYPTION_KEY:v1`).
  defaultKmsKeyId String?
  deal            Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id        String           @id @default(cuid())
  dealId    String           @unique
  year      Int
  make      String
  model     String
  vin       String
  mileage   Int
  condition VehicleCondition
  deal      Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model DealFinancials {
  id             String  @id @default(cuid())
  dealId         String  @unique
  amountFinanced Decimal @db.Decimal(14, 2)
  ltv            Decimal @db.Decimal(8, 4)
  maxLtv         Decimal @db.Decimal(8, 4)
  taxes          Decimal @db.Decimal(14, 2)
  fees           Decimal @db.Decimal(14, 2)
  gap            Decimal @db.Decimal(14, 2)
  warranty       Decimal @db.Decimal(14, 2)
  totalSalePrice Decimal @db.Decimal(14, 2)
  deal           Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model AuthoritativeContract {
  id                        String              @id @default(cuid())
  dealId                    String              @unique
  version                   Int                 @default(1)
  /// SHA-256 over the canonical contract payload at seal time (tamper detection).
  authoritativeContractHash String
  governingLaw              String
  signatureStatus           String
  isTransferableRecord      Boolean             @default(true)
  uccCollateralDescription  Json?
  uccDebtorName             String?
  deal                      Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  generatedDocuments        GeneratedDocument[]
  parentAmendments          Amendment[]         @relation("ParentAuthoritativeContract")
}

model ContractTransactionEvent {
  id                        String                       @id @default(cuid())
  dealId                    String
  eventType                 ContractTransactionEventType
  fromEntityId              String
  toEntityId                String
  transactionDate           DateTime                     @default(now())
  considerationAmount       Float?
  auditHash                 String
  instrumentTransferEventId String?
  deal                      Deal                         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  instrumentTransferEvent   InstrumentTransferEvent?     @relation(fields: [instrumentTransferEventId], references: [id], onDelete: SetNull)

  @@index([dealId, transactionDate])
  @@index([instrumentTransferEventId])
}

model LoanPool {
  id                        String               @id @default(cuid())
  lenderId                  String
  poolName                  String
  poolType                  LoanPoolType
  description               String?              @db.Text
  recourseStatus            RecourseStatus       @default(WITHOUT_RECOURSE)
  targetSize                Float
  status                    LoanPoolStatus       @default(DRAFT)
  totalLoanCount            Int                  @default(0)
  totalPrincipalBalance     Decimal              @default(0) @db.Decimal(18, 2)
  weightedAverageApr        Decimal?             @db.Decimal(8, 6)
  weightedAverageTermMonths Int?
  /// Lender-defined risk bucket label (DealSeal does not score credit).
  riskClassification        String?
  poolIntegrityStatus       DealComplianceStatus @default(COMPLIANT)
  auditStatus               String               @default("PENDING")
  saleStage                 LoanPoolSaleStage    @default(NONE)
  transferDate              DateTime?
  transferEntityName        String?
  custodyTransitionJson     Json?
  filterCriteriaJson        Json?
  lastPackageStorageKey     String?
  lastPackageGeneratedAt    DateTime?
  createdByUserId           String?
  lender                    Workspace            @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  createdBy                 User?                @relation("LoanPoolCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deals                     Deal[]
  lenderTasks               LenderTask[]
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@index([lenderId, status])
}

model NegotiableInstrument {
  id                   String                    @id @default(cuid())
  dealId               String                    @unique
  instrumentType       NegotiableInstrumentType
  payToOrderOf         String
  isBearerInstrument   Boolean                   @default(false)
  isElectronicNote     Boolean                   @default(true)
  eNoteControlLocation String?
  hdcStatus            HdcStatus                 @default(UNEVALUATED)
  hdcDefects           Json?
  deal                 Deal                      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  transferEvents       InstrumentTransferEvent[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
}

model InstrumentTransferEvent {
  id                   String                     @id @default(cuid())
  dealId               String
  instrumentId         String
  fromEntityId         String
  toEntityId           String
  transferType         InstrumentTransferType
  transferDate         DateTime                   @default(now())
  endorsementLanguage  String?
  deal                 Deal                       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  instrument           NegotiableInstrument       @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  linkedContractEvents ContractTransactionEvent[]

  @@index([dealId, transferDate])
  @@index([instrumentId, transferDate])
}

model GeneratedDocument {
  id                        String                 @id @default(cuid())
  dealId                    String
  authoritativeContractId   String?
  amendmentId               String?
  type                      GeneratedDocumentType
  documentType              DocumentType?
  fileUrl                   String?
  version                   Int                    @default(1)
  isAuthoritative           Boolean                @default(false)
  authoritativeContractHash String?
  valuesSnapshot            Json                   @default("{}")
  /// Object key in abstract storage (S3 key or local path fragment); no PII in path segments.
  storageKey                String?
  /// STORAGE_DRIVER label: LOCAL | S3 | etc.
  storageProvider           String                 @default("LOCAL")
  integritySha256           String?
  lifecycleStage            DocumentLifecycleStage @default(UPLOADED_OR_GENERATED)
  provenance                DocumentProvenance     @default(SYSTEM)
  deal                      Deal                   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authoritativeContract     AuthoritativeContract? @relation(fields: [authoritativeContractId], references: [id], onDelete: SetNull)
  amendment                 Amendment?             @relation(fields: [amendmentId], references: [id], onDelete: SetNull)
  versions                  DocumentVersion[]
  custodyEvents             DocumentCustodyEvent[]
  createdAt                 DateTime               @default(now())
}

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  dealId      String?
  type        String
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isRead, createdAt])
  @@index([userId, isRead, createdAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  prefix      String
  scopes      String[]  @default(["deals:write"])
  hashedKey   String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, revokedAt, createdAt])
}

model WebhookEndpoint {
  id          String            @id @default(cuid())
  workspaceId String
  url         String
  secret      String
  isActive    Boolean           @default(true)
  events      String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([workspaceId, isActive])
}

model WebhookDelivery {
  id                 String                @id @default(cuid())
  webhookEndpointId  String
  eventId            String
  payload            Json
  responseStatusCode Int?
  deliveryStatus     WebhookDeliveryStatus @default(PENDING)
  retryCount         Int                   @default(0)
  nextRetryAt        DateTime?
  lastError          String?
  createdAt          DateTime              @default(now())
  webhookEndpoint    WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, createdAt])
  @@index([eventId])
}

model UserAccessAudit {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  fullName    String
  title       String?
  phone       String?
  ipAddress   String?
  userAgent   String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
}

model DealComment {
  id               String        @id @default(cuid())
  dealId           String
  authorId         String
  parentCommentId  String?
  linkedEntityType String?
  linkedEntityId   String?
  body             String        @db.Text
  isException      Boolean       @default(false)
  isResolved       Boolean       @default(false)
  resolvedById     String?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deal             Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author           User          @relation("DealCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent           DealComment?  @relation("DealCommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          DealComment[] @relation("DealCommentThread")
  resolvedBy       User?         @relation("DealCommentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentCommentId])
}

model DealAlert {
  id             String            @id @default(cuid())
  dealId         String
  workspaceId    String
  type           String
  severity       DealAlertSeverity @default(WARNING)
  title          String
  message        String
  status         DealAlertStatus   @default(OPEN)
  resolutionNote String?
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  deal           Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  audits         DealAlertAudit[]

  @@index([dealId, status, createdAt])
  @@index([workspaceId, status, createdAt])
}

model DealAlertAudit {
  id              String               @id @default(cuid())
  dealAlertId     String
  action          DealAlertAuditAction
  actorUserId     String?
  actorRole       String?
  recipientUserId String?
  note            String?
  createdAt       DateTime             @default(now())
  dealAlert       DealAlert            @relation(fields: [dealAlertId], references: [id], onDelete: Cascade)

  @@index([dealAlertId, createdAt])
}

model AccountRecoveryToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt, usedAt])
}

model UserLoginOverride {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Amendment {
  id                            String                @id @default(cuid())
  dealId                        String
  parentAuthoritativeContractId String
  reason                        AmendmentReason
  amendedFields                 Json                  @default("{}")
  status                        AmendmentStatus       @default(PENDING_LENDER_APPROVAL)
  requestingUserId              String
  approvingUserId               String?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  approvedAt                    DateTime?
  deal                          Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  parentAuthoritativeContract   AuthoritativeContract @relation("ParentAuthoritativeContract", fields: [parentAuthoritativeContractId], references: [id], onDelete: Restrict)
  requestingUser                User                  @relation("AmendmentRequester", fields: [requestingUserId], references: [id], onDelete: Cascade)
  approvingUser                 User?                 @relation("AmendmentApprover", fields: [approvingUserId], references: [id], onDelete: SetNull)
  generatedDocuments            GeneratedDocument[]

  @@index([dealId, status, createdAt])
}

model DocumentCustodyEvent {
  id          String             @id @default(cuid())
  dealId      String
  documentId  String?
  eventType   CustodyEventType
  actorUserId String
  actorRole   String
  metadata    Json               @default("{}")
  timestamp   DateTime           @default(now())
  deal        Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document    GeneratedDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([dealId, timestamp])
}

model DocumentVersion {
  id                  String            @id @default(cuid())
  generatedDocumentId String
  diff                Json              @default("{}")
  createdBy           String?
  createdAt           DateTime          @default(now())
  generatedDocument   GeneratedDocument @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)
}

model ComplianceCheck {
  id                  String               @id @default(cuid())
  dealId              String
  ruleSet             ComplianceRuleSet
  status              DealComplianceStatus
  affectedField       String?
  explanation         String
  ruleSource          String
  suggestedCorrection String?
  deal                Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt           DateTime             @default(now())
}

model PreFundingValidationCertificate {
  id           String               @id @default(cuid())
  dealId       String               @unique
  lenderId     String
  dealerId     String
  status       DealComplianceStatus
  /// Full structured outcomes for every compliance rule evaluation at issuance (SOC 2 CC8.1 evidence).
  ruleChecks   Json                 @default("[]")
  warnings     Json                 @default("[]")
  blockers     Json                 @default("[]")
  documentList Json                 @default("[]")
  contractHash String
  auditRef     String
  /// Once true, row is immutable (WORM) — enforced in Prisma extension + services.
  immutable    Boolean              @default(true)
  deal         Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
}

/// Append-only deal lifecycle audit (hash-chained). Writes only via `recordDealAuditEvent`.
model DealAuditEvent {
  id                String   @id @default(cuid())
  dealId            String?
  workspaceId       String?
  actorUserId       String?
  actorRole         String?
  authMethod        String?
  action            String
  entityType        String?
  entityId          String?
  deltaBefore       Json?
  deltaAfter        Json?
  payloadJson       Json     @default("{}")
  ipAddress         String?
  previousChainHash String?
  chainHash         String?
  createdAt         DateTime @default(now())
  deal              Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([chainHash])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
