{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build -w @dealseal/shared && npm run build -w @dealseal/api"
  },
  "deploy": {
    "startCommand": "npm run start -w @dealseal/api",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
